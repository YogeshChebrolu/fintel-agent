# Copy to apps/api/.env
PORT=8787
# Convex deployment URL (same value as NEXT_PUBLIC_CONVEX_URL); printed by `convex dev`.
CONVEX_URL=https://your-deployment.convex.cloud
# Comma-separated allowed browser origins for CORS.
WEB_ORIGIN=http://localhost:3000
# DeepSeek API key for the Fin agent (get one at https://platform.deepseek.com/api_keys).
DEEPSEEK_API_KEY=sk-...
# OpenRouter API key — only needed if you switch the agent back to OpenRouter.
OPENROUTER_API_KEY=sk-or-v1-...
