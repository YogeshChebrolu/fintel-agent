# =============================================================================
# fintel-agent — environment variables
# Copy the relevant blocks into the per-app env files noted below, OR keep them
# here and your tools will still pick most of them up. Never commit real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex  (packages/convex)
# -----------------------------------------------------------------------------
# These are written automatically into packages/convex/.env.local the first
# time you run `bunx convex dev`. You normally do NOT set them by hand:
#   CONVEX_DEPLOYMENT=dev:your-deployment-name
#
# After `convex dev` prints your deployment URL (https://<name>.convex.cloud),
# copy it into the two consumers below.

# -----------------------------------------------------------------------------
# apps/web  (Next.js)  ->  apps/web/.env.local
# -----------------------------------------------------------------------------
# Public Convex URL the browser connects to (printed by `convex dev`):
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Base URL of the Hono API (apps/api):
NEXT_PUBLIC_API_URL=http://localhost:8787

# -----------------------------------------------------------------------------
# apps/api  (Hono + Bun)  ->  apps/api/.env
# -----------------------------------------------------------------------------
PORT=8787
# Same Convex deployment URL — used by the Hono gateway via ConvexHttpClient:
CONVEX_URL=https://your-deployment.convex.cloud
# Comma-separated list of allowed browser origins for CORS:
WEB_ORIGIN=http://localhost:3000
