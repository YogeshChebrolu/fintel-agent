{
  "name": "fintel-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@fintel/web",
    "dev:api": "turbo run dev --filter=@fintel/api",
    "dev:backend": "turbo run dev --filter=@fintel/backend",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "codegen": "turbo run codegen --filter=@fintel/backend"
  },
  "packageManager": "bun@1.3.4",
  "devDependencies": {
    "turbo": "2.10.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.9.0"
  },
  "dependencies": {
    "convex": "^1.42.0"
  }
}
